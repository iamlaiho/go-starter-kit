# Application
APP_ENV=development         # development | production
PORT=8080                   # HTTP port

# Auth
JWT_SECRET=change-me        # Required: HS256 signing secret (min 32 chars recommended)

# HTTP
MAX_REQUEST_BODY_BYTES=1048576   # Default: 1MB
CORS_ALLOWED_ORIGINS=*           # Comma-separated origins; required in production
